{
	"_comment": "Ultravisor Lab — meadow DAL schema. Single source of truth for the lab.db tables that Service-StateStore manages. Edits here flow through meadow-migrationmanager (introspect → diff → migrate) on every lab boot, so adding or renaming a column is one edit, not two (no separate CREATE-TABLE-vs-migration-list drift). Lab state is internal; we deliberately omit audit columns (IDUser / GUID / Deleted) — operators don't need them and meadow's DAL works fine without.",

	"Tables":
	{
		"DBEngine":
		{
			"TableName": "DBEngine",
			"Domain": "Default",
			"Columns":
			[
				{ "Column": "IDDBEngine",    "DataType": "ID" },
				{ "Column": "Name",          "DataType": "String", "Size": "200" },
				{ "Column": "EngineType",    "DataType": "String", "Size": "64" },
				{ "Column": "Port",          "DataType": "Numeric", "Size": "int" },
				{ "Column": "InternalPort",  "DataType": "Numeric", "Size": "int" },
				{ "Column": "ContainerID",   "DataType": "String", "Size": "128" },
				{ "Column": "ContainerName", "DataType": "String", "Size": "200" },
				{ "Column": "ImageTag",      "DataType": "String", "Size": "200" },
				{ "Column": "RootUsername",  "DataType": "String", "Size": "200" },
				{ "Column": "RootPassword",  "DataType": "String", "Size": "200" },
				{ "Column": "Status",        "DataType": "String", "Size": "32" },
				{ "Column": "StatusDetail",  "DataType": "Text" },
				{ "Column": "CreateDate",    "DataType": "DateTime" },
				{ "Column": "UpdateDate",    "DataType": "DateTime" }
			],
			"MeadowSchema":
			{
				"Scope": "DBEngine",
				"DefaultIdentifier": "IDDBEngine",
				"Domain": "Default",
				"Schema":
				[
					{ "Column": "IDDBEngine",    "Type": "AutoIdentity", "Size": "Default" },
					{ "Column": "Name",          "Type": "String",       "Size": "200" },
					{ "Column": "EngineType",    "Type": "String",       "Size": "64" },
					{ "Column": "Port",          "Type": "Integer",      "Size": "int" },
					{ "Column": "InternalPort",  "Type": "Integer",      "Size": "int" },
					{ "Column": "ContainerID",   "Type": "String",       "Size": "128" },
					{ "Column": "ContainerName", "Type": "String",       "Size": "200" },
					{ "Column": "ImageTag",      "Type": "String",       "Size": "200" },
					{ "Column": "RootUsername",  "Type": "String",       "Size": "200" },
					{ "Column": "RootPassword",  "Type": "String",       "Size": "200" },
					{ "Column": "Status",        "Type": "String",       "Size": "32" },
					{ "Column": "StatusDetail",  "Type": "Text",         "Size": "Default" },
					{ "Column": "CreateDate",    "Type": "CreateDate",   "Size": "Default" },
					{ "Column": "UpdateDate",    "Type": "UpdateDate",   "Size": "Default" }
				],
				"DefaultObject":
				{
					"IDDBEngine": 0, "Name": "", "EngineType": "", "Port": 0, "InternalPort": 0,
					"ContainerID": "", "ContainerName": "", "ImageTag": "",
					"RootUsername": "", "RootPassword": "",
					"Status": "pending", "StatusDetail": "",
					"CreateDate": null, "UpdateDate": null
				}
			}
		},

